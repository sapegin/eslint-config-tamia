{
  "name": "oxlint-config-raccoon",
  "version": "9.9.2",
  "description": "Artem Sapegin’s Oxlint and Oxfmt config",
  "keywords": [
    "oxfmt",
    "oxfmtconfig",
    "oxlint",
    "oxlintconfig"
  ],
  "homepage": "https://github.com/sapegin/oxlint-config-raccoon",
  "bugs": {
    "url": "https://github.com/sapegin/oxlint-config-raccoon/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Artem Sapegin",
    "url": "https://sapegin.me/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sapegin/oxlint-config-raccoon"
  },
  "files": [
    "*.json"
  ],
  "type": "module",
  "exports": {
    ".": "./base.json",
    "./base": "./base.json",
    "./typescript": "./typescript.json",
    "./typescript-react": "./typescript-react.json",
    "./typescript-react-tailwind": "./typescript-react-tailwind.json",
    "./oxfmt": "./oxfmt.json"
  },
  "scripts": {
    "pretest": "npm run lint",
    "test": "vitest run",
    "posttest": "npm run format",
    "lint": "oxlint --type-aware --fix",
    "format": "oxfmt -c oxfmt.json",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "oxlint-tailwindcss": "^0.8.0",
    "oxlint-tsgolint": "^0.22.1",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "oxfmt": "*",
    "oxlint": "*",
    "oxlint-tailwindcss": "*",
    "oxlint-tsgolint": "*"
  },
  "peerDependenciesMeta": {
    "oxlint-tailwindcss": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  }
}
