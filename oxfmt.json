{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "sortImports": {},
  "sortPackageJson": true,
  "sortTailwindcss": {
    "functions": ["clsx", "cn", "cva", "tw", "twMerge", "twJoin"]
  },
  "overrides": [
    {
      "files": ["*.md"],
      "options": {
        "arrowParens": "avoid",
        "printWidth": 70,
        "proseWrap": "never",
        "trailingComma": "none",
        "useTabs": false
      }
    }
  ]
}
