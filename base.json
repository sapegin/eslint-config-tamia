{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "jsdoc", "promise", "unicorn", "vitest"],
  "categories": {
    "correctness": "error"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "rules": {
    // Enforces return statements in callbacks of array's methods
    "array-callback-return": "error",
    // Require curly braces for all control statements
    "curly": ["error", "all"],
    // Encourages use of dot notation whenever possible
    "dot-notation": ["error", { "allowKeywords": true }],
    // Require the use of === and !==
    "eqeqeq": ["error", "smart"],
    // Disallow the use of alert, confirm, and prompt
    "no-alert": "error",
    // Disallow adding to native types
    "no-extend-native": "error",
    // Disallow unnecessary function binding
    "no-extra-bind": "error",
    // Disallow the type conversions with shorter notations
    "no-implicit-coercion": "error",
    // Disallow usage of __iterator__ property
    "no-iterator": "error",
    // Disallow use of labels for anything other then loops and switches
    "no-labels": ["error", { "allowLoop": true, "allowSwitch": true }],
    // Disallow unnecessary nested blocks
    "no-lone-blocks": "error",
    // Disallow creation of functions within loops
    "no-loop-func": "error",
    // Disallow use of multiline strings
    "no-multi-str": "error",
    // Disallows creating new instances of String, Number, and Boolean
    "no-new-wrappers": "error",
    // Disallow usage of __proto__ property
    "no-proto": "error",
    // Disallow use of assignment in return statement
    "no-return-assign": "error",
    // Disallow use of `javascript:` URLs
    "no-script-url": "error",
    // Disallow comparisons where both sides are exactly the same
    "no-self-compare": "error",
    // Disallow use of comma operator
    "no-sequences": "error",
    // Restrict what can be thrown as an exception
    "no-throw-literal": "error",
    // Disallow unmodified conditions of loops
    "no-unmodified-loop-condition": "error",
    // Disallow usage of expressions in statement position
    "no-unused-expressions": "error",
    // Disallow unnecessary .call() and .apply()
    "no-useless-call": "error",
    // Disallow unnecessary concatenation of literals or template literals
    "no-useless-concat": "error",
    // Disallow redundant return statements
    "no-useless-return": "error",
    // Disallow use of void operator
    "no-void": ["error", { "allowAsStatement": true }],
    // Disallow async functions which have no await expression
    "require-await": "error",
    // Disallow Yoda conditions
    "yoda": ["error", "never", { "exceptRange": true }],
    // Disallow duplicate imports
    "no-duplicate-imports": "error",
    // Disallow unnecessary constructor
    "no-useless-constructor": "error",
    // Disallow unnecessary computed property keys on objects
    "no-useless-computed-key": "error",
    // Require let or const instead of var
    "no-var": "error",
    // Require method and property shorthand syntax for object literals
    "object-shorthand": ["error", "always"],
    // Suggest using of const declaration for variables that are never modified after declared
    "prefer-const": "error",
    // Suggest using the spread operator instead of .apply()
    "prefer-spread": "error",
    // Suggest using the rest parameters instead of arguments
    "prefer-rest-params": "error",
    // Disallow using Object.assign with an object literal as the first argument and prefer the use of object spread instead
    "prefer-object-spread": "error",
    // Disallow renaming import, export, and destructured assignments to the same name
    "no-useless-rename": "error",
    // Limits the number of parameters that can be used in the function declaration
    "max-params": [0, 5],
    // Require a capital letter for constructors
    "new-cap": ["error", { "newIsCap": true, "capIsNew": false }],
    // Disallow use of the Array constructor
    "no-array-constructor": "error",
    // Disallow use of chained assignment expressions
    "no-multi-assign": "error",
    // Disallow the use of Boolean literals in conditional expressions
    "no-unneeded-ternary": "error",
    // Disallow variable declarations from shadowing variables declared in the outer scope
    "no-shadow": "warn",
    // Disallow the Unicode Byte Order Mark (BOM)
    "unicode-bom": ["warn", "never"],

    // Enforces the use of inline type-only markers for named imports
    "import/consistent-type-specifier-style": "warn",
    // Enforces that named import blocks are not empty
    "import/no-empty-named-blocks": "warn",

    // Expects void tags to be empty of any content
    "jsdoc/empty-tags": "warn",

    // Require returning inside each then()
    "promise/always-return": "error",
    // Disallow creating promises with new Promise()
    "promise/avoid-new": "error",
    // Ensure that each time a then() is applied to a promise, a catch() must be applied as well
    "promise/catch-or-return": "error",
    // Warns of paths that resolve multiple times in executor functions that Promise constructors
    "promise/no-multiple-resolved": "error",
    // Disallow nested then() or catch() statements
    "promise/no-nesting": "error",
    // Disallows calling new on static Promise methods
    "promise/no-new-statics": "warn",
    // Disallows the use of Promises within error-first callback functions
    "promise/no-promise-in-callback": "error",
    // Disallow return statements in a finally() callback of a promise
    "promise/no-return-in-finally": "error",
    // Enforce standard parameter names for Promise constructors
    "promise/param-names": "error",
    // Encourages the use of async/await for handling asynchronous code instead of traditional callback functions
    "promise/prefer-await-to-callbacks": "error",
    // Prefer await to then()/catch()/finally() for reading Promise values
    "promise/prefer-await-to-then": "error",
    // Prefer catch to then(a, b) and then(null, b)
    "promise/prefer-catch": "error",
    // Disallow use of non-standard Promise static methods
    "promise/spec-only": "error",

    // Enforces consistent and descriptive naming for error variables in catch statements
    "unicorn/catch-error-name": "warn",
    // Enforces the use of the direct Date cloning instead of using .getTime() for conversion
    "unicorn/consistent-date-clone": "warn",
    // Consistent type while spreading a ternary in an array
    "unicorn/consistent-empty-array-spread": "error",
    // Enforce consistent style for element existence checks
    "unicorn/consistent-existence-index-check": "warn",
    // Disallow functions that are declared in a scope which does not capture any variables from the outer scope
    "unicorn/consistent-function-scoping": "error",
    // Enforce consistent style for escaping ${ in template literals
    "unicorn/consistent-template-literal-escape": "warn",
    // Enforces the only valid way of Error subclassing
    "unicorn/custom-error-definition": "error",
    // Enforces providing a message when creating built-in Error objects
    "unicorn/error-message": "error",
    // Enforces defining escape sequence values with uppercase characters
    "unicorn/escape-case": "warn",
    // Enforce explicitly comparing the length or size property of a value
    "unicorn/explicit-length-check": "warn",
    // Enforces or disallows the use of new for the builtins
    "unicorn/new-for-builtins": "error",
    // Disallows oxlint-disable or eslint-disable comments without specifying rules
    "unicorn/no-abusive-eslint-disable": "error",
    // Disallow recursive access to this within getters and setters
    "unicorn/no-accessor-recursion": "error",
    // Disallows anonymous functions and classes as default exports
    "unicorn/no-anonymous-default-export": "error",
    // Forbids the use of Array#forEach in favor of a for loop
    "unicorn/no-array-for-each": "error",
    // Disallows the use of the thisArg parameter in array iteration methods
    "unicorn/no-array-method-this-argument": "error",
    // Prefer using Array#toReversed() over Array#reverse()
    "unicorn/no-array-reverse": "warn",
    // Prefer using Array#toSorted() over Array#sort()
    "unicorn/no-array-sort": "warn",
    // Disallows member access from await expressions
    "unicorn/no-await-expression-member": "error",
    // Disallows leading/trailing space inside console.log()
    "unicorn/no-console-spaces": "warn",
    // Disallows direct use of document.cookie
    "unicorn/no-document-cookie": "error",
    // Enforces a convention of using Unicode escapes instead of hexadecimal escapes
    "unicorn/no-hex-escape": "warn",
    // Disallows mutating a variable immediately after initialization
    "unicorn/no-immediate-mutation": "error",
    // Require Array.isArray() instead of instanceof Array
    "unicorn/no-instanceof-array": "warn",
    // Disallows the use of instanceof with ECMAScript built-in constructors
    "unicorn/no-instanceof-builtins": "error",
    // Disallow using length as the end argument of a slice call
    "unicorn/no-length-as-slice-end": "warn",
    // Disallow if statements as the only statement in if blocks without else
    "unicorn/no-lonely-if": "error",
    // Disallow magic numbers for Array.prototype.flat depth
    "unicorn/no-magic-array-flat-depth": "error",
    // Disallow negated conditions
    "unicorn/no-negated-condition": "error",
    // Disallow negated expressions on the left of (in)equality checks
    "unicorn/no-negation-in-equality-check": "error",
    // Disallows deeply nested ternary expressions
    "unicorn/no-nested-ternary": "error",
    // Disallows the deprecated new Buffer() constructor
    "unicorn/no-new-buffer": "error",
    // Disallow the use of an object literal as a default value for a parameter
    "unicorn/no-object-as-default-parameter": "error",
    // Disallow class declarations that exclusively contain static members
    "unicorn/no-static-only-class": "error",
    // Disallow assigning this to a variable
    "unicorn/no-this-assignment": "error",
    // Disallow typeof comparisons with undefined
    "unicorn/no-typeof-undefined": "error",
    // Disallows passing 1 to Array.prototype.flat
    "unicorn/no-unnecessary-array-flat-depth": "error",
    // Disallows passing .length or Infinity as the deleteCount or skipCount argument of Array#splice() or Array#toSpliced()
    "unicorn/no-unnecessary-array-splice-count": "warn",
    // Disallows unnecessarily passing a second argument to slice(...)
    "unicorn/no-unnecessary-slice-end": "warn",
    // Disallows destructuring values from an array in ways that are difficult to read
    "unicorn/no-unreadable-array-destructuring": "error",
    // Disallows IIFEs with a parenthesized arrow function body.
    "unicorn/no-unreadable-iife": "error",
    // Disallow useless values or fallbacks in Set, Map, WeakSet, or WeakMap
    "unicorn/no-useless-collection-argument": "error",
    // Disallows unnecessary Error.captureStackTrace(…) in error constructors
    "unicorn/no-useless-error-capture-stack-trace": "error",
    // Disallow unnecessary .toArray() on iterators
    "unicorn/no-useless-iterator-to-array": "warn",
    // Disallows returning values wrapped in Promise.resolve or Promise.reject in an async function or a Promise#then/catch/finally callback
    "unicorn/no-useless-promise-resolve-reject": "warn",
    // Disallows useless default cases in switch statements
    "unicorn/no-useless-switch-case": "error",
    // Prevents the use of zero fractions
    "unicorn/no-zero-fractions": "warn",
    // Enforces proper case for numeric literals
    "unicorn/number-literal-case": "warn",
    // Enforces a convention of grouping digits using numeric separators
    "unicorn/numeric-separators-style": "warn",
    // Enforces the use of .addEventListener() and .removeEventListener() over their on-function counterparts
    "unicorn/prefer-add-event-listener": "error",
    // Encourages using Array.prototype.find instead of filter(...)[0]
    "unicorn/prefer-array-find": "error",
    // Prefers Array#flat() over legacy techniques to flatten arrays
    "unicorn/prefer-array-flat": "error",
    // Prefers the use of .flatMap() when map().flat() are used together
    "unicorn/prefer-array-flat-map": "warn",
    // Enforces using indexOf or lastIndexOf instead of findIndex or findLastIndex when the callback is a simple strict equality comparison
    "unicorn/prefer-array-index-of": "error",
    // Prefers using Array#some() over Array#find(), Array#findLast() with comparing to undefined, or Array#findIndex(), Array#findLastIndex() and a non-zero length check on the result of Array#filter()
    "unicorn/prefer-array-some": "error",
    // Prefer the Array#at() and String#at() methods for index access
    "unicorn/prefer-at": "error",
    // Requires using BigInt literals (e.g. 123n) instead of calling the BigInt() constructor
    "unicorn/prefer-bigint-literals": "warn",
    // Recommends using Blob#text() and Blob#arrayBuffer() over FileReader#readAsText() and FileReader#readAsArrayBuffer()
    "unicorn/prefer-blob-reading-methods": "error",
    // Prefers class field declarations over this assignments in constructors for static values
    "unicorn/prefer-class-fields": "warn",
    // Prefers the use of element.classList.toggle(className, condition) over conditional add/remove patterns
    "unicorn/prefer-classlist-toggle": "warn",
    // Prefers usage of String.prototype.codePointAt over String.prototype.charCodeAt. Prefers usage of String.fromCodePoint over String.fromCharCode
    "unicorn/prefer-code-point": "warn",
    // Prefers use of Date.now() over new Date().getTime() or new Date().valueOf()
    "unicorn/prefer-date-now": "warn",
    // Instead of reassigning a function parameter, default parameters should be used
    "unicorn/prefer-default-parameters": "warn",
    // Enforces the use of document.body.append(div); over document.body.appendChild(div); for DOM nodes
    "unicorn/prefer-dom-node-append": "warn",
    // Use .dataset on DOM elements over getAttribute(…), .setAttribute(…), .removeAttribute(…) and .hasAttribute(…)
    "unicorn/prefer-dom-node-dataset": "warn",
    // Prefers the use of child.remove() over parentNode.removeChild(child)
    "unicorn/prefer-dom-node-remove": "error",
    // Enforces the use of .textContent over .innerText for DOM nodes
    "unicorn/prefer-dom-node-text-content": "warn",
    // Prefers EventTarget over EventEmitter
    "unicorn/prefer-event-target": "error",
    // Enforces the use of globalThis instead of environment‑specific global object aliases (window, self, or global)
    "unicorn/prefer-global-this": "error",
    // Prefer import.meta.{dirname,filename} over legacy techniques for getting file paths
    "unicorn/prefer-import-meta-properties": "warn",
    // Prefer includes() over indexOf() when checking for existence or non-existence. All built-ins have .includes() in addition to .indexOf()
    "unicorn/prefer-includes": "error",
    // Enforces the use of KeyboardEvent#key over KeyboardEvent#keyCode, which is deprecated
    "unicorn/prefer-keyboard-event-key": "warn",
    // This rule finds ternary expressions that can be simplified to a logical operator
    "unicorn/prefer-logical-operator-over-ternary": "error",
    // Prefers use of Math.min() and Math.max() instead of ternary expressions when performing simple comparisons
    "unicorn/prefer-math-min-max": "warn",
    // Prefers use of Math.trunc() instead of bitwise operations
    "unicorn/prefer-math-trunc": "error",
    // Enforces the use of modern DOM APIs
    "unicorn/prefer-modern-dom-apis": "error",
    // Checks for usage of legacy patterns for mathematical operations
    "unicorn/prefer-modern-math-apis": "error",
    // Prefer JavaScript modules (ESM) over CommonJS
    "unicorn/prefer-module": "error",
    // Prefers built in functions, over custom ones with the same functionality
    "unicorn/prefer-native-coercion-functions": "error",
    // Prefer using a negative index over .length - index when possible
    "unicorn/prefer-negative-index": "warn",
    // Prefer using the node:protocol when importing Node.js builtin modules
    "unicorn/prefer-node-protocol": "warn",
    // Disallows use of parseInt(), parseFloat(), isNan(), isFinite(), Nan, Infinity and -Infinity as global variables
    "unicorn/prefer-number-properties": "error",
    // Encourages using Object.fromEntries when converting an array of key-value pairs into an object
    "unicorn/prefer-object-from-entries": "error",
    // Prefers omitting the catch binding parameter if it is unused
    "unicorn/prefer-optional-catch-binding": "warn",
    // This rule prefers borrowing methods from the prototype instead of the instance
    "unicorn/prefer-prototype-methods": "warn",
    // Prefer .querySelector() over .getElementById()
    "unicorn/prefer-query-selector": "warn",
    // Disallows the use of Function.prototype.apply() and suggests using Reflect.apply() instead
    "unicorn/prefer-reflect-apply": "error",
    // Prefers RegExp#test() over String#match() and String#exec()
    "unicorn/prefer-regexp-test": "warn",
    // Enforces the use of Response.json() over new Response(JSON.stringify())
    "unicorn/prefer-response-static-json": "error",
    // Enforces the use of the spread operator (...) over outdated patterns
    "unicorn/prefer-spread": "warn",
    // Prefers String#replaceAll() over String#replace() when using a regex with the global flag
    "unicorn/prefer-string-replace-all": "warn",
    // Prefer String#slice() over String#substr() and String#substring()
    "unicorn/prefer-string-slice": "warn",
    // String#trimLeft() and String#trimRight() are aliases of String#trimStart() and String#trimEnd(). This is to ensure consistency and use direction-independent wording
    "unicorn/prefer-string-trim-start-end": "warn",
    // Prefer using structuredClone to create a deep clone
    "unicorn/prefer-structured-clone": "error",
    // Prefer top-level await over top-level promises and async function calls
    "unicorn/prefer-top-level-await": "error",
    // Enforce throwing a TypeError instead of a generic Error after a type checking if-statement
    "unicorn/prefer-type-error": "warn",
    // Enforce consistent relative URL style
    "unicorn/relative-url-style": "warn",
    // Enforce using the separator argument with Array#join()
    "unicorn/require-array-join-separator": "warn",
    // Enforces non-empty attribute list in import/export statements and import() expressions
    "unicorn/require-module-attributes": "warn",
    // Enforce non-empty specifier list in import and export statements
    "unicorn/require-module-specifiers": "warn",
    // Enforce using the digits argument with Number#toFixed()
    "unicorn/require-number-to-fixed-digits-argument": "warn",
    // Enforce using the targetOrigin argument with window.postMessage()
    "unicorn/require-post-message-target-origin": "warn",
    // Enforces consistent casing for text encoding identifiers
    "unicorn/text-encoding-identifier-case": "warn",
    // Makes sure you always use new when throwing an error
    "unicorn/throw-new-error": "warn"
  },
  "overrides": [
    {
      "files": ["**/*.{spec,test}.*"],
      "rules": {
        // Consistently use *.test.ts instead of .spec.ts
        "vitest/consistent-test-filename": [
          "error",
          { "pattern": ".*\\.test\\.[tj]sx?$" }
        ],
        // Consistently use test() instead of it()
        "vitest/consistent-test-it": [
          "warn",
          { "fn": "test", "withinDescribe": "test" }
        ],
        // Consistently use vi.* instead of vitest.*
        "vitest/consistent-vitest-vi": "warn",
        // Enforces Vitest's canonical matcher names instead of aliases
        "vitest/no-alias-methods": "warn",
        // Disallows duplicate hooks in describe blocks
        "vitest/no-duplicate-hooks": "error",
        // Disallow focused tests such as test.only()
        "vitest/no-focused-tests": "error",
        // Report when two test suites or two test cases at the same level of a test suite have the same title
        "vitest/no-identical-title": "error",
        // Warns when node:test is imported
        "vitest/no-import-node-test": "error",
        // Disallow explicitly returning from tests
        "vitest/no-test-return-statement": "error",
        // Disallows unnecessary async function wrapper for expected promises
        "vitest/no-unneeded-async-expect-function": "warn",
        // It checks when a target is asserted with both toHaveBeenCalledOnce and toHaveBeenCalledWith instead of toHaveBeenCalledExactlyOnceWith
        "vitest/prefer-called-exactly-once-with": "error",
        // Substitute toBeCalledTimes(1) and toHaveBeenCalledTimes(1) with toBeCalledOnce() and toHaveBeenCalledOnce() respectively
        "vitest/prefer-called-once": "warn",
        // Suggest using toBeCalledWith() or toHaveBeenCalledWith()
        "vitest/prefer-called-with": "warn",
        // This rule checks for comparisons in tests that could be replaced with one of the following built-in comparison matchers
        "vitest/prefer-comparison-matcher": "warn",
        // When testing a specific function, enforce passing a named function to describe() instead of an equivalent hardcoded string
        "vitest/prefer-describe-function-title": "warn",
        // This rule enforces using each rather than manual loops
        "vitest/prefer-each": "error",
        // Enforce use of toEqual() and toStrictEqual()
        "vitest/prefer-equality-matcher": "error",
        // Prefer await expect(...).resolves over expect(await ...) when testing promises
        "vitest/prefer-expect-resolves": "warn",
        // Enforce using expectTypeOf instead of expect(typeof ...)
        "vitest/prefer-expect-type-of": "warn",
        // Ensures that hooks are in the order that they are called in
        "vitest/prefer-hooks-in-order": "error",
        // Ensures that hooks are defined at the top
        "vitest/prefer-hooks-on-top": "error",
        // Enforces using a dynamic import() in vi.mock() or vi.doMock()
        "vitest/prefer-import-in-mock": "warn",
        // Enforces explicit imports from 'vitest' instead of using vitest globals
        "vitest/prefer-importing-vitest-globals": "warn",
        // Enforce it, test, describe, and bench to have descriptions that begin with a lowercase letter
        "vitest/prefer-lowercase-title": "warn",
        // Prefer shorthand methods like mockResolvedValue() and mockRejectedValue()
        "vitest/prefer-mock-promise-shorthand": "warn",
        // Prefer shorthand methods like mockReturnValue()
        "vitest/prefer-mock-return-shorthand": "warn",
        // Prefer spyOn() over overwriting a properties
        "vitest/prefer-spy-on": "error",
        // Enforce using toBe(true) and toBe(false) over matchers that coerce types to boolean
        "vitest/prefer-strict-boolean-matchers": "warn",
        // Disallow using toEqual() to assert equality
        "vitest/prefer-strict-equal": "warn",
        // Recommends using toBe matcher for primitive literals and specific matchers for null, undefined, and NaN
        "vitest/prefer-to-be": "warn",
        // Enforces using toBeObject() to check if a value is of type Object
        "vitest/prefer-to-be-object": "warn",
        // Enforces using toContain()
        "vitest/prefer-to-contain": "warn",
        // toHaveBeenCalledTimes() should be used instead of directly checking the length of mock.calls
        "vitest/prefer-to-have-been-called-times": "warn",
        // toHaveLength() should be used upon asserting expectations on objects length property
        "vitest/prefer-to-have-length": "warn",
        // When test cases are empty then it is better to mark them as test.todo
        "vitest/prefer-todo": "warn",
        // Disallow setup code outside of hooks or describe/test blocks
        "vitest/require-hook": "warn"
      }
    }
  ]
}
