{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": ["./typescript.json"],
  "plugins": ["react", "jsx-a11y"],
  "rules": {
    // Enforces explicit type attribute for all the button HTML elements
    "react/button-has-type": "error",
    // Enforces onChange or readOnly attribute for checked property of input elements
    "react/checked-requires-onchange-or-readonly": "error",
    // Ensure destructuring and symmetric naming of useState hook value and setter variables
    "react/hook-use-state": "error",
    // Enforce sandbox attribute on iframe elements
    "react/iframe-missing-sandbox": "error",
    // Enforces the use of shorthand syntax for boolean attributes
    "react/jsx-boolean-value": "warn",
    // Disallow unnecessary JSX expressions
    "react/jsx-curly-brace-presence": "warn",
    // Enforces the shorthand form for React Fragments
    "react/jsx-fragments": "warn",
    // Ensures that any component or prop methods used to handle events are correctly prefixed
    "react/jsx-handler-names": "error",
    // Disallows JSX context provider values from taking values that will cause needless rerenders
    "react/jsx-no-constructed-context-values": "error",
    // Prevent user generated link hrefs and form actions from creating security vulnerabilities by requiring rel='noreferrer'
    "react/jsx-no-target-blank": "error",
    // Disallow unnecessary fragments
    "react/jsx-no-useless-fragment": "error",
    // Enforce PascalCase for user-defined JSX components
    "react/jsx-pascal-case": "error",
    // Warn if an element uses an Array index in its key
    "react/no-array-index-key": "error",
    // Prevents the usage of React.cloneElement
    "react/no-clone-element": "error",
    // Prevents the use of dangerouslySetInnerHTML prop
    "react/no-danger": "error",
    // Enforce that namespaces are not used in React elements
    "react/no-namespace": "error",
    // Prevents characters that you may have meant as JSX escape characters from being accidentally injected as a text node
    "react/no-unescaped-entities": "error",
    // Disallow usage of unknown DOM properties
    "react/no-unknown-property": "error",
    // Enforces the Rules of Hooks
    "react/rules-of-hooks": "error",
    // Avoid unnecessary extra closing tags on self-closing components
    "react/self-closing-comp": ["error", { "component": true, "html": false }],
    // Require that the value of the prop style be an object or a variable that is an object
    "react/style-prop-object": "error"
  }
}
